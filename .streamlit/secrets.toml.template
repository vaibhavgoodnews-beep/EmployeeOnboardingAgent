# Streamlit Secrets Management Template
# 
# To deploy on Streamlit Cloud:
# 1. Go to https://share.streamlit.io
# 2. Navigate to your app's settings (gear icon)
# 3. Click on "Secrets" in the sidebar
# 4. Copy the content below and replace with your actual API key
# 
# For local development, create this file at .streamlit/secrets.toml

GOOGLE_API_KEY = "your-google-generative-ai-api-key-here"
GEMINI_MODEL = "gemini-1.5-flash"
